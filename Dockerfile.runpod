# =============================================================================
# ACE-Step 1.5 — RunPod Serverless worker image
# =============================================================================
#
# Builds a queue-based RunPod Serverless endpoint that runs rp_handler.py.
# RunPod detects `runpod.serverless.start({"handler": handler})` and routes
# jobs to the handler. Model weights download from HuggingFace on first
# cold-start (honours HF_TOKEN for gated repos).
#
# RunPod GitHub integration:
#   - Repo: HanzalaDevops/ACE-Step-1.5
#   - Dockerfile Path: Dockerfile.runpod   <-- set this in the endpoint build config
#   - GPU: RTX 4090 (24 GB)
#
# Manual build / push:
#   docker build -f Dockerfile.runpod --platform linux/amd64 \
#     --build-arg HF_TOKEN=hf_xxx \
#     -t youruser/acestep-runpod:latest .
#   docker push youruser/acestep-runpod:latest
#
# Local smoke test (RunPod reads test_input.json automatically):
#   echo '{"input":{"prompt":"lofi hip hop, mellow piano","duration":15}}' > test_input.json
#   docker run --rm --gpus all youruser/acestep-runpod:latest
# =============================================================================

# ==================== Base image ====================
# RunPod's official PyTorch CUDA image. -devel provides nvcc, required to
# compile flash-attn on Linux x86_64. Verify the exact tag is available at
# https://hub.docker.com/r/runpod/pytorch/tags and override via --build-arg.
ARG BASE_IMAGE=runpod/pytorch:2.8.0-py3.11-cuda12.8.1-cudnn-devel-ubuntu22.04
FROM ${BASE_IMAGE}

# ==================== Build args / secrets ====================
# HF_TOKEN is accepted at build time for gated model access. It is also
# persisted to the runtime environment so first-run downloads can authenticate.
# For production, prefer setting HF_TOKEN as an endpoint secret in the RunPod
# console rather than baking it into the image.
ARG HF_TOKEN=""

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    # Persisted so runtime HF downloads can use the gated token.
    HF_TOKEN=${HF_TOKEN} \
    HUGGING_FACE_HUB_TOKEN=${HF_TOKEN} \
    # ACE-Step worker defaults (override per-endpoint in the RunPod console).
    CHECKPOINT_PATH=ACE-Step/Ace-Step1.5 \
    ACESTEP_CONFIG_PATH=acestep-v15-turbo \
    ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-1.7B \
    ACESTEP_LM_BACKEND=pt \
    ACESTEP_DEVICE=auto \
    ACESTEP_INIT_LLM=true \
    ACESTEP_OFFLOAD_TO_CPU=false \
    ACESTEP_DOWNLOAD_SOURCE=huggingface \
    TOKENIZERS_PARALLELISM=false \
    ACESTEP_DISABLE_TQDM=1 \
    TORCHAUDIO_USE_BACKEND=ffmpeg \
    # Limit flash-attn build parallelism to avoid OOM-killing the build.
    MAX_JOBS=4

# ==================== System packages ====================
RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        curl \
        wget \
        ffmpeg \
        libsndfile1 \
        libsndfile1-dev \
    && rm -rf /var/lib/apt/lists/*

# ==================== Project source ====================
WORKDIR /app
COPY . /app/

# ==================== Python dependencies ====================
RUN python -m pip install --upgrade pip setuptools wheel packaging ninja

# Install ACE-Step deps (pins torch==2.10.0+cu128 for Linux x86_64) + RunPod SDK.
#
# flash-attn is INTENTIONALLY EXCLUDED here. Its build script imports torch,
# but pip build-isolation hides torch during the build, so it fails with
# "ModuleNotFoundError: No module named 'torch'" and aborts the whole install.
# It is only an optional speedup — every flash_attn import in the codebase is
# guarded by try/except ImportError and falls back to PyTorch SDPA. Dropping it
# makes the build fast and reliable. (To add it later: install torch first,
# then `pip install flash-attn --no-build-isolation`.)
#
# NOTE: no `|| true` here — a dependency failure MUST fail the build instead of
# silently pushing a broken image.
RUN grep -ivE '^flash-attn' requirements.txt > /tmp/requirements.runpod.txt \
    && python -m pip install -r /tmp/requirements.runpod.txt

# Optional: nano-vllm enables the "vllm" LM backend. Best-effort only — the
# default backend is "pt", so a failure here must NOT break the image.
RUN python -m pip install --no-build-isolation -e acestep/third_parts/nano-vllm \
    || echo "WARN: nano-vllm not installed (vllm backend unavailable; pt backend still works)"

# Persist model cache outside the (ephemeral) layer when a network volume is
# mounted at /runpod-volume; otherwise weights land in /app/checkpoints.
RUN mkdir -p /app/checkpoints /app/output

# ==================== Sanity check ====================
# Real import check — this would have caught the previous broken build where
# pip installed nothing. Importing torch/runpod does NOT require a GPU.
RUN python -c "import ast; ast.parse(open('rp_handler.py').read())" \
    && python -c "import torch, runpod, soundfile, transformers, diffusers; print('deps OK — torch', torch.__version__)"

# ==================== Entrypoint ====================
# RunPod invokes the handler defined here; rp_handler.py loads models once at
# import, then calls runpod.serverless.start({'handler': handler}).
CMD ["python", "-u", "rp_handler.py"]
