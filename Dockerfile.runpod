# =============================================================================
# ACE-Step 1.5 — RunPod Serverless worker image
# =============================================================================
#
# Builds a queue-based RunPod Serverless endpoint that runs rp_handler.py.
# RunPod detects `runpod.serverless.start({"handler": handler})` and routes
# jobs to the handler. The core ACE-Step 1.5 weights are baked INTO the image
# at build time (see "Bake model weights" below) and served from
# /app/checkpoints, so cold-starts never download from HuggingFace. HF_TOKEN is
# only needed at build time for gated-repo access.
#
# RunPod GitHub integration:
#   - Repo: HanzalaDevops/ACE-Step-1.5
#   - Dockerfile Path: Dockerfile.runpod   <-- set this in the endpoint build config
#   - GPU: RTX 4090 (24 GB)
#
# Manual build / push:
#   docker build -f Dockerfile.runpod --platform linux/amd64 \
#     --build-arg HF_TOKEN=hf_xxx \
#     -t youruser/acestep-runpod:latest .
#   docker push youruser/acestep-runpod:latest
#
# Local smoke test (RunPod reads test_input.json automatically):
#   echo '{"input":{"prompt":"lofi hip hop, mellow piano","duration":15}}' > test_input.json
#   docker run --rm --gpus all youruser/acestep-runpod:latest
# =============================================================================

# ==================== Base image ====================
# RunPod's official PyTorch CUDA image. -devel provides nvcc, required to
# compile flash-attn on Linux x86_64. Verify the exact tag is available at
# https://hub.docker.com/r/runpod/pytorch/tags and override via --build-arg.
ARG BASE_IMAGE=runpod/pytorch:2.8.0-py3.11-cuda12.8.1-cudnn-devel-ubuntu22.04
FROM ${BASE_IMAGE}

# ==================== Build args / secrets ====================
# HF_TOKEN is accepted at build time ONLY to authenticate the model download
# below (gated repos). It is intentionally NOT persisted into the runtime
# environment: the weights are baked into the image, so the worker never
# downloads at runtime and never needs the token. Keeping the credential out of
# the final image ENV means it cannot leak via `docker inspect` or a shell in a
# running container. For production, pass it as `--build-arg HF_TOKEN=...` (or a
# BuildKit secret) rather than committing it anywhere.
ARG HF_TOKEN=""

# Which DiT (diffusion) model to bake into the image. Defaults to the base
# model. It is its OWN HuggingFace repo (ACE-Step/<name>) — NOT bundled in the
# main ACE-Step/Ace-Step1.5 repo — so it must be downloaded separately at build
# time (see "Bake model weights" below). The runtime ACESTEP_CONFIG_PATH is tied
# to this value so the worker loads exactly what was baked and never downloads it
# again on cold-start. Override per build:
#   docker build --build-arg DIT_MODEL=acestep-v15-sft ...
ARG DIT_MODEL=acestep-v15-base

# Which 5Hz LM (Chain-of-Thought / "thinking") to bake. The 1.7B is bundled in
# the main repo; the 0.6B and 4B are SEPARATE repos (ACE-Step/<name>). The LM
# loader does NOT auto-download — it only checks <checkpoints>/<LM_MODEL> and, if
# missing, silently falls back to pure-DiT (thinking disabled). So a non-1.7B LM
# MUST be baked here. Tied to runtime ACESTEP_LM_MODEL_PATH. Override per build:
#   docker build --build-arg LM_MODEL=acestep-5Hz-lm-1.7B ...
ARG LM_MODEL=acestep-5Hz-lm-4B

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    # Xet-based high-performance accelerator for the build-time HF download
    # (replaces the deprecated HF_HUB_ENABLE_HF_TRANSFER / hf_transfer path).
    HF_XET_HIGH_PERFORMANCE=1 \
    # Serve the weights baked into the image. Do NOT default to /runpod-volume
    # in serverless — cold-starts must not depend on a mounted network volume.
    ACESTEP_CHECKPOINTS_DIR=/app/checkpoints \
    # ACE-Step worker defaults (override per-endpoint in the RunPod console).
    CHECKPOINT_PATH=ACE-Step/Ace-Step1.5 \
    ACESTEP_CONFIG_PATH=${DIT_MODEL} \
    ACESTEP_LM_MODEL_PATH=${LM_MODEL} \
    ACESTEP_LM_BACKEND=pt \
    ACESTEP_DEVICE=auto \
    ACESTEP_INIT_LLM=true \
    ACESTEP_OFFLOAD_TO_CPU=false \
    ACESTEP_DOWNLOAD_SOURCE=huggingface \
    TOKENIZERS_PARALLELISM=false \
    ACESTEP_DISABLE_TQDM=1 \
    TORCHAUDIO_USE_BACKEND=ffmpeg \
    # Limit flash-attn build parallelism to avoid OOM-killing the build.
    MAX_JOBS=4

# ==================== System packages ====================
RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        curl \
        wget \
        ffmpeg \
        libsndfile1 \
        libsndfile1-dev \
    && rm -rf /var/lib/apt/lists/*

# ==================== Bake model weights into the image ====================
# Download ALL weights the worker needs at BUILD time so cold-starts never hit
# HuggingFace:
#   1. ACE-Step/Ace-Step1.5 (main repo)  -> vae, text encoder, turbo DiT, 1.7B LM
#   2. ACE-Step/${DIT_MODEL}             -> the configured DiT (e.g. base) — a
#      SEPARATE repo. The DiT loader auto-downloads it at cold-start when missing,
#      so without baking it re-downloads on every new worker's ephemeral layer.
#   3. ACE-Step/${LM_MODEL}              -> the configured 5Hz LM (e.g. 4B) — also
#      a SEPARATE repo. The LM loader does NOT auto-download; if missing it
#      silently falls back to pure-DiT and disables thinking mode. Baking is the
#      only way to make a non-1.7B LM available on every worker.
# Each step skips automatically when the model is already present (e.g. bundled
# in the main repo), so every worker reuses the image-layer copy and never
# re-downloads on cold-start.
# This runs BEFORE `COPY . /app/` so editing source code does not bust the
# multi-GB weights layer; `checkpoints/` is .dockerignore'd, so the COPY below
# never overwrites what we bake here.
#
# Security: HF_TOKEN is passed inline to the download command only. It is never
# echoed to the build log (Docker logs the literal `$HF_TOKEN`, not its value),
# never written to a token file (no `hf auth login`), and never set in
# the runtime ENV — so the final image carries no credential.
#
# NOTE: `huggingface-cli` was removed in huggingface_hub >= 1.0 (it now errors
# out with "deprecated and no longer works"). The current entrypoint is `hf`,
# which ships with the base package, and high-performance transfer is enabled
# via HF_XET_HIGH_PERFORMANCE (hf_transfer / HF_HUB_ENABLE_HF_TRANSFER are
# likewise deprecated and ignored).
RUN python -m pip install -U "huggingface_hub>=1.0" \
    && mkdir -p /app/checkpoints \
    && if [ -n "$HF_TOKEN" ]; then \
         echo "HF_TOKEN provided — authenticating download for gated repo"; \
       else \
         echo "No HF_TOKEN — downloading public weights anonymously"; \
       fi \
    && export HF_TOKEN="$HF_TOKEN" HUGGING_FACE_HUB_TOKEN="$HF_TOKEN" \
    && ( HF_XET_HIGH_PERFORMANCE=1 hf download ACE-Step/Ace-Step1.5 --local-dir /app/checkpoints \
         || ( echo "Accelerated download failed — retrying without Xet high-performance" \
              && HF_XET_HIGH_PERFORMANCE=0 \
                 hf download ACE-Step/Ace-Step1.5 --local-dir /app/checkpoints ) ) \
    && echo "Baking DiT model: ${DIT_MODEL}" \
    && if [ -n "$(ls -A "/app/checkpoints/${DIT_MODEL}" 2>/dev/null)" ]; then \
         echo "DiT '${DIT_MODEL}' already present from main repo — skipping submodel download"; \
       else \
         ( HF_XET_HIGH_PERFORMANCE=1 hf download "ACE-Step/${DIT_MODEL}" --local-dir "/app/checkpoints/${DIT_MODEL}" \
           || ( echo "Accelerated download failed — retrying without Xet high-performance" \
                && HF_XET_HIGH_PERFORMANCE=0 \
                   hf download "ACE-Step/${DIT_MODEL}" --local-dir "/app/checkpoints/${DIT_MODEL}" ) ); \
       fi \
    && echo "Baking 5Hz LM: ${LM_MODEL}" \
    && if [ -n "$(ls -A "/app/checkpoints/${LM_MODEL}" 2>/dev/null)" ]; then \
         echo "LM '${LM_MODEL}' already present from main repo — skipping submodel download"; \
       else \
         ( HF_XET_HIGH_PERFORMANCE=1 hf download "ACE-Step/${LM_MODEL}" --local-dir "/app/checkpoints/${LM_MODEL}" \
           || ( echo "Accelerated download failed — retrying without Xet high-performance" \
                && HF_XET_HIGH_PERFORMANCE=0 \
                   hf download "ACE-Step/${LM_MODEL}" --local-dir "/app/checkpoints/${LM_MODEL}" ) ); \
       fi \
    && echo "Baked checkpoints into image (top-level):" \
    && ls -1 /app/checkpoints

# ==================== Project source ====================
WORKDIR /app
COPY . /app/

# ==================== Python dependencies ====================
RUN python -m pip install --upgrade pip setuptools wheel packaging ninja

# Install ACE-Step deps (pins torch==2.10.0+cu128 for Linux x86_64) + RunPod SDK.
#
# flash-attn is INTENTIONALLY EXCLUDED here. Its build script imports torch,
# but pip build-isolation hides torch during the build, so it fails with
# "ModuleNotFoundError: No module named 'torch'" and aborts the whole install.
# It is only an optional speedup — every flash_attn import in the codebase is
# guarded by try/except ImportError and falls back to PyTorch SDPA. Dropping it
# makes the build fast and reliable. (To add it later: install torch first,
# then `pip install flash-attn --no-build-isolation`.)
#
# NOTE: no `|| true` here — a dependency failure MUST fail the build instead of
# silently pushing a broken image.
RUN grep -ivE '^flash-attn' requirements.txt > /tmp/requirements.runpod.txt \
    && python -m pip install -r /tmp/requirements.runpod.txt

# Optional: nano-vllm enables the "vllm" LM backend. Best-effort only — the
# default backend is "pt", so a failure here must NOT break the image.
RUN python -m pip install --no-build-isolation -e acestep/third_parts/nano-vllm \
    || echo "WARN: nano-vllm not installed (vllm backend unavailable; pt backend still works)"

# Weights are already baked into /app/checkpoints above; this just guarantees
# the output dir exists (and is a no-op for checkpoints if it already does).
RUN mkdir -p /app/checkpoints /app/output

# ==================== Sanity check ====================
# Real import check — this would have caught the previous broken build where
# pip installed nothing. Importing torch/runpod does NOT require a GPU.
RUN python -c "import ast; ast.parse(open('rp_handler.py').read())" \
    && python -c "import torch, runpod, soundfile, transformers, diffusers; print('deps OK — torch', torch.__version__)"

# ==================== Entrypoint ====================
# RunPod invokes the handler defined here; rp_handler.py loads models once at
# import, then calls runpod.serverless.start({'handler': handler}).
CMD ["python", "-u", "rp_handler.py"]
