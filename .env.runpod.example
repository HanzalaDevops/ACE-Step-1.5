# =============================================================================
# ACE-Step 1.5 — RunPod Serverless environment variables (rp_handler.py)
# =============================================================================
# Set these as Environment Variables / Secrets on your RunPod endpoint
# (Console -> Serverless -> your endpoint -> Settings). They are read once at
# container cold-start by rp_handler.py. Defaults shown are baked into
# Dockerfile.runpod; override here only what you need to change.
#
# Copy to .env for local testing:  cp .env.runpod.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Cloudinary (REQUIRED) — where generated audio is stored
# ---------------------------------------------------------------------------
# The worker uploads each generated track to Cloudinary and returns its URL
# (instead of inline base64), so the response stays small and long songs never
# hit RunPod's /job-done response-size limit. The job is rejected with a clear
# error if credentials are missing. Prefer RunPod *Secrets* over plaintext vars.
#
# Credentials (from Cloudinary Console -> Dashboard):
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
#
# (Alternative to the 3 vars above: a single CLOUDINARY_URL connection string.)
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
#
# Per request, pass the full upload path in "cloudinary_folder" in the job input,
# e.g. {"input": {"prompt": "...", "cloudinary_folder": "acestep/songs/user123"}}.

# ---------------------------------------------------------------------------
# HuggingFace authentication (REQUIRED for gated repos / reliable downloads)
# ---------------------------------------------------------------------------
# Token used by snapshot_download on first cold-start. Prefer a RunPod *Secret*
# over a plaintext env var in production.
HF_TOKEN=hf_your_token_here
# huggingface_hub also reads this alias; keep both in sync.
HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# ---------------------------------------------------------------------------
# Model selection
# ---------------------------------------------------------------------------
# Core weights repo (VAE + text encoder + default DiT). Point at a fork if you
# host your own mirror. Default: ACE-Step/Ace-Step1.5
CHECKPOINT_PATH=ACE-Step/Ace-Step1.5

# DiT (diffusion) model variant. "acestep-v15-turbo" is fast and ships inside
# the main repo — best for serverless cold-starts.
ACESTEP_CONFIG_PATH=acestep-v15-turbo

# 5Hz language model for Chain-of-Thought reasoning. Options:
#   acestep-5Hz-lm-0.6B | acestep-5Hz-lm-1.7B | acestep-5Hz-lm-4B
# 1.7B is bundled in the main repo (no extra download) and fits a 24GB 4090.
ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-1.7B

# LM backend: "pt" (PyTorch-native, most robust) or "vllm" (faster, needs the
# bundled nano-vllm; installed in Dockerfile.runpod).
ACESTEP_LM_BACKEND=pt

# ---------------------------------------------------------------------------
# Runtime / hardware
# ---------------------------------------------------------------------------
# Device selection: auto | cuda | cpu | xpu
ACESTEP_DEVICE=auto

# Initialize the 5Hz LM at startup. false = pure-DiT mode (faster, less VRAM,
# no "thinking"/CoT). true (default) enables thinking mode.
ACESTEP_INIT_LLM=true

# CPU offload. false on a 24GB 4090 (everything fits). Set true on smaller GPUs.
ACESTEP_OFFLOAD_TO_CPU=false

# Preferred download source: huggingface | modelscope | auto
ACESTEP_DOWNLOAD_SOURCE=huggingface

# RECOMMENDED: serve weights from a RunPod Network Volume so they are NOT
# re-downloaded on every cold-start (the #1 cause of /runsync timeouts).
#   1. Console -> Storage -> create a Network Volume.
#   2. Attach it to your endpoint; it mounts at /runpod-volume.
#   3. Pre-fetch the weights ONCE from a temporary Pod with the volume mounted:
#        export HF_TOKEN=hf_xxx
#        python scripts/prefetch_models.py
#   4. Set the variable below on the endpoint. Honoured by BOTH the DiT
#      pipeline and the 5Hz LM loader.
ACESTEP_CHECKPOINTS_DIR=/runpod-volume/checkpoints

# ---------------------------------------------------------------------------
# Generation defaults & safety bounds (optional)
# ---------------------------------------------------------------------------
# Default diffusion steps when a job omits "inference_steps"/"steps"
# (turbo: ~8, base DiT: ~60).
ACESTEP_DEFAULT_STEPS=8
# Hard upper bounds applied to per-job overrides.
ACESTEP_MAX_DURATION=600
ACESTEP_MAX_STEPS=200
# Max tracks per request (batch_size is clamped to this).
ACESTEP_MAX_BATCH_SIZE=8
